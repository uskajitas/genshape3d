PORT=8110
CLIENT_ORIGIN_URL=http://localhost:3110,https://genshape3d.com

# Postgres (WSL2 Ubuntu, accessed from Windows via wslrelay on localhost:5432)
DATABASE_URL=postgresql://genshape3d:CHANGEME@localhost:5432/genshape3d

# Cloudflare R2 (object storage for uploads/meshes) - fill if using R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=genshape3d

# Admin emails (comma separated)
ADMIN_EMAILS=usquiano@gmail.com

# ─── Stripe billing ──────────────────────────────────────────────────────────
# Public URL of the frontend (Stripe redirects users back here after checkout).
APP_PUBLIC_URL=http://localhost:3110

# Stripe API keys — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — `stripe listen --forward-to localhost:8110/api/billing/webhook`
# prints this on startup, or copy from the dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each credit pack (create one-time products in Stripe).
# Starter pack: $3 → 10 credits.   Creator pack: $10 → 40 credits.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_CREATOR=price_...

# fal.ai — premium text-to-image provider (Flux Schnell + Pro 1.1)
# Sign up at https://fal.ai, generate a key under Account → Keys.
# NOTE: keys belong to a specific account — record which one here so the
# next agent doesn't end up signed in as the wrong identity.
# (Live key is on the usquiano@gmail.com account, NOT uskajitas.)
FAL_KEY=

# Hugging Face — free-tier Flux Schnell text-to-image fallback
# Sign up at https://huggingface.co/settings/tokens, create a "Read" token.
HF_TOKEN=

# OpenAI — DALL-E 3 image generation
# Get a key at https://platform.openai.com/api-keys (separate from ChatGPT).
# Live key is on the usquiano@gmail.com account.
OPENAI_API_KEY=
